# VoidAI (OpenAI-compatible, required)
VOIDAI_API_KEY=your_voidai_api_key_here
VOIDAI_BASE_URL=https://api.voidai.app/v1

# WaveSpeed image generation (required)
WAVESPEED_API_KEY=your_wavespeed_api_key_here

# VoiceAPI / ElevenLabs TTS (required)
VOICEAPI_KEY=your_voiceapi_key_here
DEFAULT_VOICE_ID=your_default_voice_id_here

# Transcriber integration (optional — defaults to known paths)
TRANSCRIBER_PY=D:/transscript batch/Transcriber/transcriber.py
TRANSCRIBER_OUTPUT=D:/transscript batch/output/output

# YouTube API (required for upload module)
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
